{
  "name": "e-commerce_server",
  "version": "1.0.0",
  "description": "",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "node --check server.js",
    "seed": "npm run seed:catalog --",
    "db:seed": "npm run seed:catalog --",
    "seed:catalog": "node scripts/seedCatalog.js",
    "seed:production": "node scripts/seedCatalog.js",
    "seed:keys": "node scripts/seedLicenseKeyPool.js",
    "seed:admin": "node scripts/seedAdmin.js",
    "reset:db": "node scripts/resetDatabase.js",
    "vnpay:mock": "node scripts/vnpayMock.js",
    "migrate:categories": "node scripts/migrateCategories.js",
    "migrate:categories:v2": "node scripts/migrateCategoriesV2.js",
    "test": "node --test \"test/**/*.test.js\"",
    "test:unit": "node --test test/validators.test.js test/orderLifecycle.test.js test/vnpayAmount.test.js test/vnpaySignature.test.js",
    "test:integration": "node --test --test-concurrency=1 test/*.api.integration.test.js test/cart-payment.integration.test.js test/race.integration.test.js",
    "test:coverage": "node --experimental-test-coverage --test \"test/**/*.test.js\"",
    "seed:test": "node scripts/seedTestData.js",
    "mongo:init-replica": "node scripts/initReplicaSet.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.6.2",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.10"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  }
}
