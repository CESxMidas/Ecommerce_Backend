# Copy to .env.test for isolated QA database (recommended)
# Local MongoDB must run as replica set (transactions). See scripts/setup-mongo-replica-set.ps1
TEST_MONGODB_URL=mongodb://127.0.0.1:27017/keyshop_qa?replicaSet=rs0
JWT_SECRET=test-jwt-secret-keyshop-qa
JWT_EXPIRES_IN=1h
NODE_ENV=test

# Optional — same as .env if using shared dev DB (not recommended for CI)
# MONGODB_URL=mongodb://127.0.0.1:27017/ecommerce
