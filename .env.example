NODE_ENV=development
PORT=888
API_URL=http://localhost:888
# Local FE (Next.js :3000). Production: thêm origin Vercel, phân cách bằng dấu phẩy
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001

# Database
MONGODB_URL="mongodb://user:password@host:27017/ecommerceApp?authSource=admin"

# JWT
JWT_SECRET=dev_ecommerce_jwt_change_in_production
JWT_EXPIRES_IN=7d
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_DAYS=30

# Rate limit
RATE_LIMIT_MAX=500
AUTH_RATE_LIMIT_MAX=30

# Gmail
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Seed accounts (optional overrides for npm run seed:admin)
# OWNER_SEED_EMAIL=owner@keyshop.vn
# OWNER_SEED_PASSWORD=Owner@123456

# Email API for deployed demo on hosts that block SMTP
RESEND_API_KEY=
EMAIL_FROM=

# Google Sign-In — cùng Client ID với FE (.env NEXT_PUBLIC_GOOGLE_CLIENT_ID)
GOOGLE_CLIENT_ID=

# Cloudinary (bắt buộc cho upload ảnh sản phẩm, banner, avatar người dùng)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# VNPay Sandbox
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_PAYMENT_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
# Chỉ dùng khi đơn hàng currency=USD (quy đổi sang VND). Đơn VND không nhân thêm.
VNPAY_EXCHANGE_RATE=25000
